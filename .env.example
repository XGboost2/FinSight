# FinSight AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === LLM ===
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === SEC EDGAR ===
# Format: "AppName your@email.com" — required by SEC fair access policy.
SEC_EDGAR_USER_AGENT=FinSight your@email.com

# === Vector DB ===
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100
QDRANT_HNSW_FULL_SCAN_THRESHOLD=10000
QDRANT_HNSW_EF_SEARCH=128

# === Redis ===
REDIS_PASSWORD=replace_with_local_redis_password
REDIS_URL=redis://:replace_with_local_redis_password@redis:6379

# === Neo4j ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_local_neo4j_password
NEO4J_AUTH=neo4j/replace_with_local_neo4j_password
NEO4J_DATABASE=neo4j

# === Retrieval ===
DOCUMENT_UPLOAD_MAX_BYTES=26214400

# === Local Multimodal Models ===
MULTIMODAL_SERVICE_URL=http://multimodal:8010
MULTIMODAL_TIMEOUT_SECONDS=120
MULTIMODAL_IMAGE_MAX_BYTES=10485760
MULTIMODAL_AUDIO_MAX_BYTES=26214400

# === Observability ===
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# === News ===
FINNHUB_API_KEY=

# === Trading 212 (Invest/Stocks ISA practice account; generate key in app Settings > API) ===
# Demo: https://demo.trading212.com/api/v0   Live: https://live.trading212.com/api/v0
TRADING212_API_KEY_ID=
TRADING212_API_SECRET=
TRADING212_BASE_URL=https://demo.trading212.com/api/v0
TRADING212_ALLOW_LIVE=false

# === Admin ===
FINSIGHT_ADMIN_KEY=

# === Sessions ===
SESSION_TTL_SECONDS=3600

# === Frontend (Vite — prefix VITE_ to expose to browser) ===
VITE_API_URL=http://localhost:8000
VITE_ALPHA_VANTAGE_KEY=
