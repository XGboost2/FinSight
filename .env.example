# FinSight AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === LLM ===
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === SEC EDGAR ===
# Format: "AppName your@email.com" — required by SEC fair access policy.
SEC_EDGAR_USER_AGENT=FinSight your@email.com

# === Vector DB ===
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# === Redis ===
REDIS_PASSWORD=replace_with_local_redis_password
REDIS_URL=redis://:replace_with_local_redis_password@redis:6379

# === Neo4j ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_local_neo4j_password
NEO4J_AUTH=neo4j/replace_with_local_neo4j_password
NEO4J_DATABASE=neo4j

# === Retrieval ===
DOCUMENT_UPLOAD_MAX_BYTES=26214400

# === Observability ===
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# === News ===
FINNHUB_API_KEY=

# === Admin ===
FINSIGHT_ADMIN_KEY=

# === Sessions ===
SESSION_TTL_SECONDS=3600

# === Frontend (Vite — prefix VITE_ to expose to browser) ===
VITE_API_URL=http://localhost:8000
VITE_ALPHA_VANTAGE_KEY=
