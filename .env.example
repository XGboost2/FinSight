# FinSight AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!

# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === SEC EDGAR ===
# Format: "AppName your@email.com" — required by SEC fair access policy
SEC_EDGAR_USER_AGENT=FinSight your@email.com

# === Vector DB (Day 14+) ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=



# === Cache (Day 49+) ===
REDIS_URL=redis://localhost:6379

# === Frontend (Vite — prefix VITE_ to expose to browser) ===
# Free key at: https://www.alphavantage.co/support/#api-key
VITE_ALPHA_VANTAGE_KEY=your_key_here
VITE_API_URL=http://localhost:8000
