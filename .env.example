# FinSight AI — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!

# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === SEC EDGAR ===
# Format: "AppName your@email.com" — required by SEC fair access policy
SEC_EDGAR_USER_AGENT=FinSight your@email.com

# === Vector DB ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# === Observability ===
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# === Cache ===
REDIS_URL=redis://localhost:6379

# === News ===
# Free key at: https://finnhub.io
FINNHUB_API_KEY=your_key_here

# === Frontend (Vite — prefix VITE_ to expose to browser) ===
VITE_API_URL=http://localhost:8000
VITE_ALPHA_VANTAGE_KEY=your_key_here
